{
  // ActDefend application configuration
  // All tunable parameters live here — no magic numbers in code.
  // Reload at runtime is NOT supported in Phase 1; restart required after changes.

  "ActDefend": {

    // ── Logging ─────────────────────────────────────────────────────────────
    "Logging": {
      // Root directory for rolling structured log files (JSON compact format).
      // Relative paths are resolved from the executable directory.
      "LogDirectory": "logs",
      // Rolling interval: Hour | Day | Month | Year | Infinite
      "RollingInterval": "Day",
      // Maximum retained files (0 = unlimited)
      "RetainedFileCountLimit": 30,
      // Minimum log level: Verbose | Debug | Information | Warning | Error | Fatal
      "MinimumLevel": "Information"
    },

    // ── Storage ──────────────────────────────────────────────────────────────
    "Storage": {
      // Path to SQLite database file. Relative = beside the executable.
      "DatabasePath": "actdefend.db"
    },

    // ── ETW Collector ────────────────────────────────────────────────────────
    "Collector": {
      // Capacity of the in-memory event queue between collector and feature extractor.
      // If full, excess events are dropped and a warning is logged.
      "EventQueueCapacity": 4096,
      // How long (ms) to wait for a slot when the queue is full before dropping.
      "EventQueueTimeoutMs": 5
    },

    // ── Feature Extraction ───────────────────────────────────────────────────
    "Features": {
      // Short primary window for burst detection (seconds).
      "PrimaryWindowSeconds": 5,
      // Wider context window for signal stabilisation (seconds).
      "ContextWindowSeconds": 15,
      // How often the feature extractor emits a FeatureSnapshot per process (seconds).
      "EmitIntervalSeconds": 2,
      // Remove per-process state after this many seconds of inactivity.
      "InactivityExpirySeconds": 120
    },

    // ── Stage 1 — Lightweight Scoring ────────────────────────────────────────
    "Stage1": {
      // Score >= this threshold triggers Stage 2.
      "SuspicionThreshold": 60.0,
      // Per-feature weights (0–100 normalised).
      "Weights": {
        "WriteRate":          20.0,
        "UniqueFilesWritten": 20.0,
        "RenameRate":         25.0,
        "DirectorySpread":    20.0,
        "WriteReadRatio":     15.0
      },
      // Normalisation upper bounds (count/rate values that map to weight * 1.0)
      "Thresholds": {
        "WriteRatePerSec":          10.0,
        "UniqueFilesPerWindow":     30,
        "RenameRatePerSec":          5.0,
        "UniqueDirectoriesPerWindow": 10,
        "WriteReadRatioMax":         5.0
      }
    },

    // ── Stage 2 — Entropy Sampling ───────────────────────────────────────────
    "Stage2": {
      // Minimum Shannon entropy (bits/byte) to consider a file as potentially encrypted.
      // Random/encrypted data typically scores 7.5–8.0; plaintext ~4.0–6.0.
      "EntropyThreshold": 7.2,
      // Maximum bytes to read per file for entropy estimation.
      "SampleBytesLimit": 65536,
      // Maximum files to sample per Stage 2 trigger.
      "MaxFilesToSample": 5,
      // Minimum number of high-entropy files needed to confirm detection.
      "ConfirmationMinFiles": 2,
      // Minimum cool-down between Stage 2 checks for the same process (seconds).
      "CooldownSeconds": 10
    },

    // ── Trusted Processes ────────────────────────────────────────────────────
    "TrustedProcesses": {
      // Well-known Windows system processes excluded from scoring by default.
      // These are baseline exclusions; user additions are stored in the database.
      "DefaultExclusions": [
        "System",
        "smss.exe",
        "csrss.exe",
        "wininit.exe",
        "winlogon.exe",
        "services.exe",
        "lsass.exe",
        "svchost.exe",
        "MsMpEng.exe",
        "SearchIndexer.exe"
      ]
    },

    // ── Simulator ────────────────────────────────────────────────────────────
    "Simulator": {
      // Simulator will ONLY operate inside this directory (absolute or relative).
      // Must be set explicitly before running the simulator.
      "WorkspaceDirectory": "",
      // Number of test files to create.
      "FileCount": 100,
      // Simulated rename burst interval (ms).
      "RenameIntervalMs": 50
    }
  }
}
