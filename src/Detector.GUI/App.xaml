<Application x:Class="ActDefend.GUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <!-- Phase 1: Minimal resource dictionary.
             Phase 6 will add full theme: colours, fonts, control styles. -->

        <!-- Brand colours (placeholder — Phase 6 will expand) -->
        <Color x:Key="PrimaryColor">#1A1A2E</Color>
        <Color x:Key="AccentColor">#E94560</Color>
        <Color x:Key="SurfaceColor">#16213E</Color>
        <Color x:Key="TextPrimary">#EAEAEA</Color>
        <Color x:Key="WarningColor">#F5A623</Color>
        <Color x:Key="DangerColor">#E94560</Color>
        <Color x:Key="SafeColor">#27AE60</Color>

        <SolidColorBrush x:Key="PrimaryBrush"  Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="AccentBrush"   Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="SurfaceBrush"  Color="{StaticResource SurfaceColor}" />
        <SolidColorBrush x:Key="TextBrush"      Color="{StaticResource TextPrimary}" />
        <SolidColorBrush x:Key="WarningBrush"  Color="{StaticResource WarningColor}" />
        <SolidColorBrush x:Key="DangerBrush"   Color="{StaticResource DangerColor}" />
        <SolidColorBrush x:Key="SafeBrush"     Color="{StaticResource SafeColor}" />
    </Application.Resources>
</Application>
