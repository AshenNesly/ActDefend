<Window x:Class="ActDefend.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="ActDefend — Ransomware Early Warning"
        Height="640" Width="940"
        MinHeight="480" MinWidth="720"
        Background="{StaticResource PrimaryBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Tray icon — resolves from the embedded Images/shield.ico resource -->
        <tb:TaskbarIcon x:Name="TaskbarIcon"
                        IconSource="/ActDefend.GUI;component/Images/shield.ico"
                        ToolTipText="ActDefend — Ransomware Monitor"
                        TrayMouseDoubleClick="TaskbarIcon_TrayMouseDoubleClick" />

        <!-- Title bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="⛨" FontSize="22" Margin="0,0,10,0" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="ActDefend" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                <TextBlock Text=" — Ransomware Early Warning System" FontSize="13" Foreground="#888" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Status sidebar -->
            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="SYSTEM STATUS" FontSize="11" FontWeight="Bold" Foreground="#666" Margin="0,0,0,8"/>

                <Border CornerRadius="6" Padding="12" Margin="0,0,0,8" Background="{StaticResource SurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="ELEVATION" FontSize="10" Foreground="#888"/>
                        <TextBlock Text="{Binding ElevationText}" FontSize="14" FontWeight="Bold"
                                   Foreground="{Binding ElevationBrush}"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="6" Padding="12" Margin="0,0,0,8" Background="{StaticResource SurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="COLLECTOR" FontSize="10" Foreground="#888"/>
                        <TextBlock Text="{Binding CollectorText}" FontSize="14" FontWeight="Bold"
                                   Foreground="{Binding CollectorBrush}"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="6" Padding="12" Margin="0,0,0,8" Background="{StaticResource SurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="EVENTS PROCESSED" FontSize="10" Foreground="#888"/>
                        <TextBlock Text="{Binding EventsProcessed}" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="6" Padding="12" Margin="0,0,0,8" Background="{StaticResource SurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="TRACKED PROCESSES" FontSize="10" Foreground="#888"/>
                        <TextBlock Text="{Binding TrackedProcesses}" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="6" Padding="12" Margin="0,0,0,8" Background="{StaticResource SurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="EVENTS DROPPED" FontSize="10" Foreground="#888"/>
                        <TextBlock Text="{Binding EventsDropped}" FontSize="14" FontWeight="Bold"
                                   Foreground="{Binding DroppedBrush}"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="6" Padding="12" Margin="0,0,0,8" Background="{StaticResource SurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="UPTIME" FontSize="10" Foreground="#888"/>
                        <TextBlock Text="{Binding UptimeText}" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Alert feed -->
            <Border Grid.Column="1" CornerRadius="6" Background="{StaticResource SurfaceBrush}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="RECENT ALERTS" FontSize="11" FontWeight="Bold"
                                   Foreground="#666" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AlertCountText}" FontSize="11"
                                   Foreground="#555" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ListView Grid.Row="1" ItemsSource="{Binding RecentAlerts}"
                              Background="Transparent" BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1a1a2e" CornerRadius="4" Padding="10,8"
                                        Margin="0,0,0,6"
                                        BorderBrush="{Binding SeverityBrush}" BorderThickness="3,0,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Border Background="{Binding SeverityBrush}" CornerRadius="2"
                                                        Padding="4,1" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding SeverityLabel}" FontWeight="Bold"
                                                               Foreground="#111" FontSize="9"/>
                                                </Border>
                                                <TextBlock Text="{Binding ProcessName}" FontWeight="Bold"
                                                           Foreground="{StaticResource AccentBrush}" FontSize="13"
                                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding PidText}" Foreground="#555" FontSize="11"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Summary}" Foreground="{StaticResource TextBrush}"
                                                       TextWrapping="Wrap" FontSize="12"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding TimestampText}"
                                                   Foreground="#666" FontSize="11"
                                                   VerticalAlignment="Top" Margin="12,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="12,0">
            <TextBlock Text="{Binding StatusBarText}" FontSize="11" Foreground="#666" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
