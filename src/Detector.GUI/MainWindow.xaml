<Window x:Class="ActDefend.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="ActDefend — Ransomware Early Warning"
        Height="620" Width="900"
        MinHeight="480" MinWidth="720"
        Background="{StaticResource PrimaryBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Adding Taskbar wrapper hooking MVVM strictly to avoid background death loops -->
        <tb:TaskbarIcon x:Name="TaskbarIcon"
                        IconSource="/Images/shield.ico"
                        ToolTipText="ActDefend Ransomware Monitor"
                        TrayMouseDoubleClick="TaskbarIcon_TrayMouseDoubleClick" />

        <!-- Title bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="⛨" FontSize="22" Margin="0,0,10,0" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="ActDefend" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                <TextBlock Text=" — Ransomware Early Warning System" FontSize="13" Foreground="#888" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Status panels bound strictly to ViewModel Properties -->
            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="SYSTEM STATUS" FontSize="11" FontWeight="Bold" Foreground="#666" Margin="0,0,0,8"/>

                <Border CornerRadius="6" Padding="12" Margin="0,0,0,8" Background="{StaticResource SurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="ELEVATION" FontSize="10" Foreground="#888"/>
                        <TextBlock Text="{Binding ElevationText}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource SafeBrush}"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="6" Padding="12" Margin="0,0,0,8" Background="{StaticResource SurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="COLLECTOR" FontSize="10" Foreground="#888"/>
                        <TextBlock Text="{Binding CollectorText}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource SafeBrush}"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="6" Padding="12" Margin="0,0,0,8" Background="{StaticResource SurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="EVENTS PROCESSED" FontSize="10" Foreground="#888"/>
                        <TextBlock Text="{Binding EventsProcessed}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="6" Padding="12" Margin="0,0,0,8" Background="{StaticResource SurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="TRACKED PROCESSES" FontSize="10" Foreground="#888"/>
                        <TextBlock Text="{Binding TrackedProcesses}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Active Alerts Data Grid -->
            <Border Grid.Column="1" CornerRadius="6" Background="{StaticResource SurfaceBrush}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="RECENT ALERTS" FontSize="11" FontWeight="Bold" Foreground="#666" Margin="0,0,0,12"/>

                    <ListView Grid.Row="1" ItemsSource="{Binding RecentAlerts}" 
                              Background="Transparent" BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1e1e1e" CornerRadius="4" Padding="10" Margin="0,0,0,8" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1,0,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding ProcessName}" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding Timestamp, StringFormat='{} {0:HH:mm:ss}'}" Foreground="#888"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Summary}" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="12,0">
            <TextBlock Text="Phase 6 — Live UI &amp; Persistence Active." FontSize="11" Foreground="#666" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
